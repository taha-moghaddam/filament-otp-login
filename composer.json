{
    "name": "taha-moghaddam/filament-otp-login",
    "description": "OTP Login for Filament v5 - Mobile/Phone login with OTP, no password, no session (mobile in URL)",
    "keywords": [
        "filament",
        "filament-5",
        "laravel",
        "otp",
        "login",
        "authentication",
        "mobile",
        "phone"
    ],
    "homepage": "https://github.com/taha-moghaddam/filament-otp-login",
    "license": "MIT",
    "authors": [
        {
            "name": "Taha Moghaddam",
            "email": "mtmoghaddam@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "FilamentOtpLogin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FilamentOtpLogin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilamentOtpLogin\\FilamentOtpLoginServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
